# ============================================
# HABIT TRACKER - Environment Variables Template
# ============================================
# Copy this file to .env and update the values.
# Never commit .env to version control!
# ============================================

# ------------------------------
# Database Configuration
# ------------------------------

# Path to the SQLite database file
DB_PATH=data/habits.db

# ------------------------------
# Security
# ------------------------------

# Secret key for session encryption (change this!)
SECRET_KEY=change-this-to-a-random-secret-key

# Default admin credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ------------------------------
# Application Settings
# ------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Whether to enable debug mode (True/False)
DEBUG=False

# Default streak targets
DEFAULT_DAILY_TARGET=28
DEFAULT_WEEKLY_TARGET=4
DEFAULT_MONTHLY_TARGET=4

# ------------------------------
# Guest User Settings
# ------------------------------

# Guest username and password (read-only access)
GUEST_USERNAME=guest
GUEST_PASSWORD=guest123

# ------------------------------
# Optional: External Services
# ------------------------------

# Future integrations (uncomment when needed)

# Email configuration for password reset
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# API keys (for future features)
# API_KEY=your-api-key-here

# ------------------------------
# Development & Testing
# ------------------------------

# Use in-memory database for testing (True/False)
TEST_DB_IN_MEMORY=False

# Skip seeding test data in development (True/False)
SKIP_SEED_DATA=False